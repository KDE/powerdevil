#: InhibitionItem.qml:53
#, kde-format
msgctxt "@title:group"
msgid "Sleep and Screen Locking after Inactivity"
msgstr "Suspender e Bloqueio do Ecrã após inatividade"

#: InhibitionItem.qml:60 main.qml:97 PowerProfileItem.qml:76
#, kde-format
msgid "Power Management"
msgstr "Gestão de Energia"

#: InhibitionItem.qml:65
#, kde-format
msgctxt "accessible-only status text"
msgid "Automatic sleep and screen locking are currently blocked."
msgstr ""
"A suspensão e o bloqueio do ecrã automáticos estão de momento desativados."

#: InhibitionItem.qml:67
#, kde-format
msgctxt "accessible-only status text"
msgid ""
"Screen locking is currently blocked. Sleep is automatic after inactivity."
msgstr ""
"O bloquear do ecrã está de momento desativado. A suspensão será automática "
"após inatividade."

#: InhibitionItem.qml:69
#, kde-format
msgctxt "accessible-only status text"
msgid ""
"Sleep is currently blocked. Screen locking is automatic after inactivity."
msgstr ""
"A suspensão está de momento desativada. O bloqueio do ecrã será automático "
"após inatividade."

#: InhibitionItem.qml:71
#, kde-format
msgctxt "accessible-only status text"
msgid "Sleep and screen locking are automatic after inactivity."
msgstr "A suspensão e o bloqueio do ecrã serão automáticos após inatividade."

#: InhibitionItem.qml:94
#, kde-format
msgctxt "@action:button Block sleep and screen locking after inactivity"
msgid "Manually Block Sleep and Screen Locking"
msgstr "Bloquear manualmente a suspensão e o bloqueio do ecrã"

#: InhibitionItem.qml:112
#, kde-format
msgid "Failed to unblock automatic sleep and screen locking"
msgstr "O desbloqueio automático da suspensão e do bloqueio do ecrã falhou"

#: InhibitionItem.qml:115
#, kde-format
msgid "Failed to block automatic sleep and screen locking"
msgstr "O bloqueio automático da suspensão e do bloqueio do ecrã falhou"

#: InhibitionItem.qml:129
#, kde-format
msgctxt ""
"@label corresponding to Manually Block Sleep and Screen Locking toggle"
msgid "This will result in higher energy consumption."
msgstr "Isto vai resultar num maior consumo de energia."

#: InhibitionItem.qml:130
#, kde-format
msgctxt ""
"@label accessible - the sentence about higher energy consumption must be "
"included (EU regulations)"
msgid ""
"You have manually blocked automatic sleep and screen locking. This will "
"result in higher energy consumption."
msgstr ""
"Bloqueou manualmente a suspensão e o bloqueio do ecrã automáticos. Isto vai "
"resultar num maior consumo de energia."

#: InhibitionItem.qml:137
#, kde-format
msgctxt "Minimize the length of this string as much as possible"
msgid ""
"Your laptop is configured not to sleep when closing the lid while an "
"external monitor is connected."
msgstr ""
"O seu portátil está configurado para não suspender quando fechar a tampa do "
"ecrã, enquanto estiver ligado a um monitor externo."

#: InhibitionItem.qml:156
#, kde-format
msgctxt "An application's reason for inhibiting sleep and/or screen locking"
msgid "Unknown reason."
msgstr "Razão desconhecida."

#: InhibitionItem.qml:163
#, kde-format
msgctxt ""
"Application (1) with reason (2) has been prevented from blocking this "
"inactivity behavior. The user can choose to allow it again."
msgid "%1 wants to block sleep and screen locking. (%2)"
msgstr "O %1 quer impedir a suspensão e o bloqueio do ecrã. (%2)"

#: InhibitionItem.qml:165
#, kde-format
msgctxt ""
"Application (1) with reason (2) has been prevented from blocking this "
"inactivity behavior. The user can choose to allow it again."
msgid "%1 wants to block screen locking. (%2)"
msgstr "O %1 quer a impedir o bloqueio do ecrã. (%2)"

#: InhibitionItem.qml:167
#, kde-format
msgctxt ""
"Application (1) with reason (2) has been prevented from blocking this "
"inactivity behavior. The user can choose to allow it again."
msgid "%1 wants to block sleep. (%2)"
msgstr "O %1 quer a impedir a suspensão. (%2)"

#: InhibitionItem.qml:171
#, kde-format
msgctxt ""
"Application (1) with reason (2) is currently blocking this inactivity "
"behavior, in addition to the user's manual block switch."
msgid "%1 is also blocking sleep and screen locking. (%2)"
msgstr "O %1 está também a impedir a suspensão e o bloqueio do ecrã. (%2)"

#: InhibitionItem.qml:173
#, kde-format
msgctxt ""
"Application (1) with reason (2) is currently blocking this inactivity "
"behavior, in addition to the user's manual block switch."
msgid "%1 is also blocking screen locking. (%2)"
msgstr "O %1 está também a impedir o bloqueio do ecrã. (%2)"

#: InhibitionItem.qml:175
#, kde-format
msgctxt ""
"Application (1) with reason (2) is currently blocking this inactivity "
"behavior, in addition to the user's manual block switch."
msgid "%1 is also blocking sleep. (%2)"
msgstr "O %1 está também a impedir a suspensão. (%2)"

#: InhibitionItem.qml:179
#, kde-format
msgctxt ""
"Application (1) with reason (2) is currently blocking this inactivity "
"behavior, the user can choose to unblock it."
msgid "%1 is blocking sleep and screen locking. (%2)"
msgstr "O %1 está a impedir a suspensão e o bloqueio do ecrã. (%2)"

#: InhibitionItem.qml:181
#, kde-format
msgctxt ""
"Application (1) with reason (2) is currently blocking this inactivity "
"behavior, the user can choose to unblock it."
msgid "%1 is blocking screen locking. (%2)"
msgstr "O %1 está a impedir o bloqueio do ecrã. (%2)"

#: InhibitionItem.qml:183
#, kde-format
msgctxt ""
"Application (1) with reason (2) is currently blocking this inactivity "
"behavior, the user can choose to unblock it."
msgid "%1 is blocking sleep. (%2)"
msgstr "O %1 está a impedir a suspensão. (%2)"

#: InhibitionItem.qml:191
#, kde-format
msgctxt ""
"@action:button Prevent an app from blocking automatic sleep and screen "
"locking after inactivity"
msgid "Unblock"
msgstr "Desbloquear"

#: InhibitionItem.qml:199
#, kde-format
msgctxt ""
"@action:button Undo preventing an app from blocking automatic sleep and "
"screen locking after inactivity"
msgid "Allow"
msgstr "Permitir"

#: main.qml:76
#, kde-format
msgid "The battery applet has enabled suppressing sleep and screen locking"
msgstr ""
"A 'applet' da bateria ativou a inibição da suspensão e do bloqueio do ecrã"

#: main.qml:97
#, kde-format
msgid "Power & Battery"
msgstr "Energia & Bateria"

#: main.qml:116
#, kde-format
msgid "Battery is not present in the bay"
msgstr "A Bateria não se encontra instalada"

#: main.qml:129
#, kde-format
msgid "Battery at %1%, not Charging"
msgstr "Bateria está a %1%, a não carregar"

#: main.qml:131
#, kde-format
msgid "Battery at %1%, plugged in but still discharging"
msgstr "Bateria está a %1%, ligada mas continua a descarregar"

#: main.qml:133
#, kde-format
msgid "Battery at %1%, Charging"
msgstr "Bateria está a %1%, a carregar"

#: main.qml:136
#, kde-format
msgid "Battery at %1%"
msgstr "Bateria está a %1%"

#: main.qml:144
#, kde-format
msgid "The power supply is not powerful enough to charge the battery"
msgstr ""
"A fonte de alimentação não tem capacidade suficiente para carregar a Bateria"

#: main.qml:148
#, kde-format
msgid "No Batteries Available"
msgstr "Sem Baterias disponíveis"

#: main.qml:155
#, kde-format
msgctxt "time until fully charged - HH:MM"
msgid "%1 until fully charged"
msgstr "%1 até estar totalmente carregada"

#: main.qml:157
#, kde-format
msgctxt "remaining time left of battery usage - HH:MM"
msgid "%1 remaining"
msgstr "Faltam %1"

#: main.qml:160
#, kde-format
msgid "Not charging"
msgstr "Não está a carregar"

#: main.qml:165
#, kde-format
msgid ""
"Automatic sleep and screen locking are disabled; middle-click to re-enable"
msgstr ""
"A suspensão e o bloqueio do ecrã automáticos estão desativados; clique no "
"botão do meio do rato para reativar"

#: main.qml:167
#, kde-format
msgid "Middle-click to disable automatic sleep and screen locking"
msgstr ""
"Clique no botão do meio do rato para desativar a suspensão e o bloqueio do "
"ecrã"

#: main.qml:172
#, kde-format
msgid "An application has requested activating Performance mode"
msgid_plural "%1 applications have requested activating Performance mode"
msgstr[0] "Uma aplicação solicitou a ativação do modo Melhor Desempenho"
msgstr[1] "%1 aplicações solicitaram a ativação do modo Melhor Desempenho"

#: main.qml:176
#, kde-format
msgid "System is in Performance mode; scroll to change"
msgstr ""
"O sistema está no modo Melhor Desempenho; deslize a roda do rato para alterar"

#: main.qml:180
#, kde-format
msgid "An application has requested activating Power Save mode"
msgid_plural "%1 applications have requested activating Power Save mode"
msgstr[0] ""
"Uma aplicação solicitou a ativação do modo Melhor Eficiência Energética"
msgstr[1] ""
"%1 aplicações solicitaram a ativação do modo Melhor Eficiência Energética"

#: main.qml:184
#, kde-format
msgid "System is in Power Save mode; scroll to change"
msgstr ""
"O sistema está no modo Melhor Eficiência Energética; deslize a roda do rato "
"para alterar"

#: main.qml:187
#, kde-format
msgid "System is in Balanced Power mode; scroll to change"
msgstr ""
"O sistema está no modo Equilibrado; deslize a roda do rato para alterar"

#: main.qml:301
#, kde-format
msgid "&Show Energy Information…"
msgstr "&Mostrar a informação de energia…"

#: main.qml:307
#, kde-format
