#: PowerDevilRunner.cpp:50
#, kde-format
msgid ""
"Lists system suspend (e.g. sleep, hibernate) options and allows them to be "
"activated"
msgstr ""
"Mostra as opções de suspensão do sistema (p.ex., suspender, hibernar) e "
"permite a sua ativação"

#: PowerDevilRunner.cpp:54
#, kde-format
msgid "Suspends the system to RAM"
msgstr "Suspende o sistema para a memória RAM"

#: PowerDevilRunner.cpp:58
#, kde-format
msgid "Suspends the system to disk"
msgstr "Suspende o sistema para o disco"

#: PowerDevilRunner.cpp:62
#, kde-format
msgid "Sleeps now and falls back to hibernate"
msgstr "Suspende agora e retorna para hibernação"

#: PowerDevilRunner.cpp:65
#, kde-format
msgctxt ""
"Note this is a KRunner keyword, <> is a placeholder and should be at the end"
msgid "screen brightness <percent value>"
msgstr "brilho do ecrã <percent value>"

#: PowerDevilRunner.cpp:68
#, no-c-format, kde-format
msgid ""
"Lists screen brightness options or sets it to the brightness defined by the "
"search term; e.g. screen brightness 50 would dim the screen to 50% maximum "
"brightness"
msgstr ""
"Mostra todas as opções de brilho ou configura as mesmas segundo as "
"definições no termo de pesquisa, p.ex., 'brilho do ecrã 50' iria colocar o "
"ecrã a 50% do seu brilho máximo"

#: PowerDevilRunner.cpp:89
#, kde-format
msgid "Set Brightness to %1%"
msgstr "Mudar o brilho para %1%"

#: PowerDevilRunner.cpp:98
#, kde-format
msgid "Dim screen totally"
msgstr "Escurecer o ecrã por completo"

#: PowerDevilRunner.cpp:106
#, kde-format
msgid "Dim screen by half"
msgstr "Escurecer o ecrã por metade"

