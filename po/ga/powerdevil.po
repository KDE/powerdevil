msgid "Device Battery Low (%1% Remaining)"
msgstr "Cadhnra Gléis Íseal (%1% Atá Fágtha)"

#: powerdevilcore.cpp:550
#, kde-format
msgctxt "Placeholder is device name"
msgid ""
"The battery in \"%1\" is running low, and the device may turn off at any "
"time. Please recharge or replace the battery."
msgstr ""
"Tá an cadhnra i \"%1\" a rith íseal, agus féadfaidh an gléas a mhúchadh am "
"ar bith. Athluchtaítear nó athsholáthar an cadhnra."

#: powerdevilcore.cpp:557
#, kde-format
msgid "Mouse Battery Low (%1% Remaining)"
msgstr "Cadhnra Luiche Íseal (%1% Atá Fágtha)"

#: powerdevilcore.cpp:561
#, kde-format
msgid "Keyboard Battery Low (%1% Remaining)"
msgstr "Cadhnra Méarchláir Íseal (%1% Atá Fágtha)"

#: powerdevilcore.cpp:571
#, kde-format
msgid "Bluetooth Device Battery Low (%1% Remaining)"
msgstr "Cadhnra Bluetooth Gléis Íseal (%1% Atá Fágtha)"

#: powerdevilcore.cpp:573
#, kde-format
msgctxt "Placeholder is device name"
msgid ""
"The battery in Bluetooth device \"%1\" is running low, and the device may "
"turn off at any time. Please recharge or replace the battery."
msgstr ""
"Tá an cadhnra in Bluetooth gléis \"%1\" a rith íseal, agus féadfar an gléas "
"a mhúchadh ag am ar bith. Athluchtaigh nó athraigh an cadhnra."

#: powerdevilcore.cpp:615
#, kde-format
msgid ""
"Ensure that the power cord is plugged in all the way and provides enough "
"power."
msgstr ""

#: powerdevilcore.cpp:617
#, kde-format
msgid "Plug in the power cord."
msgstr "Plugáil an corda cumhachta isteach."

#: powerdevilcore.cpp:637
#, kde-format
msgid "The system will shut down in 60 seconds."
msgstr "Múchfar an ríomhaire i gceann 60 soicind."

#: powerdevilcore.cpp:639
#, kde-format
msgctxt ""
"@action:button Shut down without waiting for the battery critical timer"
msgid "Shut Down Now"
msgstr "Múch Anois"

#: powerdevilcore.cpp:645
#, kde-format
msgid "The system will hibernate in 60 seconds."
msgstr "Geimhrítear an ríomhaire i gceann 60 soicind."

#: powerdevilcore.cpp:647
#, kde-format
msgctxt ""
"@action:button Enter hibernation mode without waiting for the battery "
"critical timer"
msgid "Hibernate Now"
msgstr "Geimhrigh Anois"

#: powerdevilcore.cpp:653
#, kde-format
msgid "The system will go to sleep in 60 seconds."
msgstr "Codlóidh an córas i 60 soicind."

#: powerdevilcore.cpp:655
#, kde-format
msgctxt ""
"@action:button Suspend to ram without waiting for the battery critical timer"
msgid "Sleep Now"
msgstr "Codail Anois"

#: powerdevilcore.cpp:661
#, kde-format
msgid "Please save your work."
msgstr "Sábháil do chuid oibre."

#: powerdevilcore.cpp:667
#, kde-format
msgctxt ""
"Cancel timeout that will automatically put system to sleep because of low "
"battery"
msgid "Cancel"
msgstr "Cealaigh"

#: powerdevilcore.cpp:682
#, kde-format
msgid "Battery Low (%1% Remaining)"
msgstr "Cadhnra Íseal (%1% Atá Fágtha)"

#: powerdevilcore.cpp:686
#, kde-format
msgid "Battery Critical (%1% Remaining)"
msgstr "Cadhnra Criticiúil (%1% Atá Fágtha)"

#: powerdevilcore.cpp:720
#, kde-format
msgid "Power Cord Plugged In"
msgstr "Corda Cumhachta Plugáilte Isteach"

#: powerdevilcore.cpp:721
#, kde-format
msgid "The computer will no longer go to sleep."
msgstr "Ní stadfaidh an ríomhaire a thuilleadh."

#: powerdevilcore.cpp:723
#, kde-format
msgid "Running on AC Power"
msgstr "Ar Chumhacht SA"

#: powerdevilcore.cpp:724
#, kde-format
msgid "The power cord has been plugged in."
msgstr "Tá an corda cumhachta plugáilte isteach."

#: powerdevilcore.cpp:736
#, kde-format
msgid "Running on Battery Power"
msgstr "Ar Chumhacht Chadhnra Ag Rith"

#: powerdevilcore.cpp:737
#, kde-format
msgid "The power cord has been unplugged."
msgstr "Bhí an cuibheoir cumhachta díphlugáilte."

#: powerdevilcore.cpp:800
#, kde-format
msgid "Charging Complete"
msgstr "Luchtú Críochnaithe"

#: powerdevilcore.cpp:800
#, kde-format
msgid "Battery now fully charged."
msgstr "Tá an cadhnra luchtaithe go hiomlán anois."

